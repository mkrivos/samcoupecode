; PASS - SAM BASIC loader, detokenised to ASCII (sambas2txt.py).
; One-way listing (binary number forms dropped); not byte-reversible.
; {FN_34} = MasterDOS file-length function (DOS extension, not in ROM).
;
10 CLS #: LET BASE=16384+32
30 FILENAME
40 LET L= {FN_34} (N$,2): MERGE N$ CODE 32768
50 LET PGS=L DIV 16384,MD=L MOD 16384: POKE BASE+2,PGS: DPOKE BASE+4,MD
60 INPUT "PASSWORD:"; LINE PASS$
70 IF PASS$="" THEN GO TO 60
80 IF LEN PASS$>31 THEN GO TO 60
90 POKE 16384,PASS$+"."
100 PRINT "CODING...": CALL BASE
110 FILENAME
120 SAVE OVER N$ CODE 32768,L
130 PRINT "OK."'"NEXT (Y/N) ?"
140 GET ANS$: IF ANS$="N" THEN STOP: ELSE IF ANS$<>"Y" THEN GO TO 140
150 CLS #: GO TO 30
600 DEF PROC FILENAME
605 INPUT "FILE NAME (RETURN=DIR):"; LINE N$
610 IF N$="" THEN DIR 1: PAUSE: CLS: GO TO 605
630 END PROC
999 STOP
1000 CLEAR 32767: LOAD "PASS1" CODE: POKE SVAR 618,8: RUN
