# Build outputs (round-trip reassembly) — regenerated by `make`
*.bin
*.o
*.gen.asm
build/
cpp/build/

# Ghidra headless decompiler output — generated reading aid only,
# NOT the canonical deliverable (regenerate with `make NAME=X ORG=0x... ghidra`)
*.ghidra.c

# Python bytecode cache
__pycache__/
*.pyc

# Editor / OS noise
*~
*.swp
.DS_Store

# NOTE: the original *.BIN code bodies (e.g. SKOMP1.BIN, ARCHIV.BIN) are
# intentionally tracked (uppercase .BIN) — they are required inputs for the
# byte-exact verification. The lowercase *.bin above is the build output only.
